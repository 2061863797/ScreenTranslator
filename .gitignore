# —— 本机环境与密钥配置 ——
venv/
.venv/
config.json

# runtime/models、runtime/llama、runtime/paddlex 一并进库（Git LFS，见 .gitattributes）

# —— 用户数据与日志 ——
*.db
*.db-*
data.db
app.log
error.log
*.log

# —— 打包产物 ——
build/
dist/
*.spec
# 根目录启动器可生成；runtime/llama 内的 server 等 exe 要进 LFS
*.exe
!runtime/llama/*.exe
翻译.exe

# —— Python / 工具缓存 ——
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
.eggs/

# —— IDE / 本机索引 ——
.codegraph/
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db
